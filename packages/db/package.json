{
  "name": "@vr-tournament/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "migrate:up": "node scripts/migrate-up.mjs",
    "migrate:down": "node scripts/migrate-down.mjs",
    "migrate:baseline": "node scripts/migrate-baseline.mjs",
    "db:repair": "node scripts/repair-schema.mjs",
    "db:reset": "node scripts/db-reset.mjs",
    "seed": "node scripts/repair-schema.mjs && tsx seeds/dev.ts"
  },
  "dependencies": {
    "@vr-tournament/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "ioredis": "^5.6.0",
    "pg": "^8.14.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/pg": "^8.11.11",
    "node-pg-migrate": "^7.9.1",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
